# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=feedbackradar

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=feedback

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Streamlit Configuration
STREAMLIT_PORT=8501

# MCP Configuration
MCP_SERVER_NAME=feedbackradar-mcp
MCP_SERVER_VERSION=0.1.0

# LangGraph Configuration
LANGGRAPH_TRACING=false

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Gmail MCP Collector Configuration (via Anthropic API)
GMAIL_MCP_POLLING_ENABLED=true
GMAIL_MCP_POLL_INTERVAL_SECONDS=60
GMAIL_MCP_SUBJECT_FILTER=notausuario
GMAIL_MCP_OUTPUT_CSV=data/raw/gmail_notausuario.csv
GMAIL_MCP_CREDENTIALS_FILE=credentials.json
GMAIL_MCP_TOKEN_FILE=token.json
GMAIL_MCP_SERVER_URL=https://gmailmcp.googleapis.com/mcp/v1

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Chat LLM Provider Selection
# "openai" = Groq API (rapido, recomendado) | "ollama" = Ollama local (sin coste, mas lento)
CHAT_LLM_PROVIDER=openai

# Groq API (OpenAI-compatible) - recomendado para agentes
# Obtener API key gratis en: https://console.groq.com
OPENAI_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_PROVIDER=
OPENAI_ORIGIN=
OPENAI_ORIGIN_DETAIL=

# Jira MCP Integration (via mcp-atlassian)
JIRA_MCP_ENABLED=false
JIRA_BASE_URL=https://yourbaseurl.atlassian.net
JIRA_USER_EMAIL=tu_email_jira6@gmail.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=KAN
JIRA_DEFAULT_ISSUE_TYPE=Task
JIRA_PRIORITY_CRITICA=Highest
JIRA_PRIORITY_ALTA=High
JIRA_DEDUP_DAYS=7
